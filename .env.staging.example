# Seniorsense — STAGING (homologação)
# ------------------------------------------------------------------------------
# SEGURANÇA: não coloque passwords reais neste ficheiro versionado.
# Use AWS Secrets Manager / parâmetros da task ECS / .env local gitignored.
#
# Se a password do Postgres contiver "#", codifique na URL como %23 (ex.: x#y -> x%23y).
# ------------------------------------------------------------------------------

NODE_ENV=production
PORT=8787

# RDS: host e DB reais; USER/PASSWORD só no secret (ex.: app_user + password rotacionada)
DATABASE_URL=postgresql://app_user:Leao311269%23seniorsense-staging-postgres.cmhe42eye8k2.us-east-1.rds.amazonaws.com:5432/appss?sslmode=require

AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_NdFHCZPAt
COGNITO_APP_CLIENT_ID=4jpb6k00gflvri85cj47di10ep
S3_RAW_BUCKET=seniorsense-staging-raw-978850043586-us-east-1-an

# URL do front staging — para CORS na API
CORS_ORIGIN=https://staging.seniorsenseplus.com

# Opcional — só até criar o primeiro SUPER_ADMIN; depois rotacionar ou remover
# BOOTSTRAP_SECRET=

# ------------------------------------------------------------------------------
