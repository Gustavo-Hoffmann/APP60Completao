## Deploy Web STAGING (S3 + CloudFront)
## Copie para `.env.deploy.staging` (não commitar) e ajuste perfis/IDs.

# Bucket do site (conta STAGING)
S3_BUCKET="seniorsenseplus-staging-web"
S3_AWS_PROFILE="staging"
AWS_REGION="us-east-1"

# CloudFront (conta MANAGEMENT)
CLOUDFRONT_DISTRIBUTION_ID="EVKKQRLQV24J6"
CLOUDFRONT_AWS_PROFILE="default"

# API + migrações RDS (scripts/deploy-staging-api.sh — use a URL do RDS staging, não commitar)
# DATABASE_URL="postgresql://usuario:senha@host-rds:5432/nome_do_banco?sslmode=require"

