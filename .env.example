# Raiz do monorepo — copie para .env local ou use os exemplos por ambiente (.env.staging.example / .env.production.example).
# Valores são placeholders; preencha com os recursos da conta AWS correta (staging vs production).

# ---------- API (Node, pasta API/app60-api) ----------
NODE_ENV=development
PORT=8787
DATABASE_URL=postgresql://app60:CHANGE_ME@localhost:5432/app60
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
S3_RAW_BUCKET=app60-raw-dev
# Opcional: chave compartilhada se expuser rotas só para o worker
# WORKER_API_KEY=
# Primeiro Super Admin (somente até existir usuário no banco)
# BOOTSTRAP_SECRET=defina_um_segredo_longo_aleatorio
CORS_ORIGIN=http://localhost:5173

# ---------- Web (Vite, pasta app60web) — prefixo VITE_ ----------
# VITE_API_BASE_URL=http://localhost:8787
# VITE_COGNITO_REGION=us-east-1
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Worker (Python, pasta Worker) ----------
# DATABASE_URL=postgresql://... (mesmo RDS que a API, usuário com leitura/escrita nas tabelas collections / collection_results)
# AWS_REGION=us-east-1
# POLL_SECONDS=10
# ENABLED_TEST_TYPES=MARCHA,SL30S,IVCF20

# ---------- Mobile (Expo) ----------
# Não usa .env na raiz: configure app60/app.json > expo.extra (apiBaseUrl, cognitoRegion, cognitoUserPoolId, cognitoClientId).
