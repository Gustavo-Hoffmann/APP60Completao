{
  "expo": {
    "name": "app60",
    "slug": "app60",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "app60",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.ufpr.app60.staging",
      "infoPlist": {
        "NSMotionUsageDescription": "O app usa acelerômetro e giroscópio para avaliar testes funcionais.",
        "NSCameraUsageDescription": "A câmera poderá ser usada em versões futuras para registro e documentação.",
        "NSMicrophoneUsageDescription": "O microfone poderá ser usado em versões futuras para gravações/observações.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "br.ufpr.app60",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.INTERNET"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-dev-client",
      "expo-sharing",
      "expo-localization"
    ],
    "extra": {
      "appName": "app60",
      "apiBaseUrl": "https://api-staging.seniorsenseplus.com",
      "cognitoRegion": "us-east-1",
      "cognitoUserPoolId": "us-east-1_NdFHCZPAt",
      "cognitoClientId": "4jpb6k00gflvri85cj47di10ep"
    }
  }
}
