# Conta AWS: PRODUCTION. Isolamento total da conta de staging (sem bucket/RDS/pool compartilhado).

NODE_ENV=production
PORT=8787
DATABASE_URL=postgresql://app60_prod:CHANGE_ME@rds-prod.xxxxxx.us-east-1.rds.amazonaws.com:5432/app60
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_PROD_POOL
COGNITO_APP_CLIENT_ID=prod_spa_client_id
S3_RAW_BUCKET=app60-prod-raw-us-east-1
# Não defina BOOTSTRAP_SECRET em produção após go-live, ou mantenha rotacionado e altamente restrito.
CORS_ORIGIN=https://app60.example.com

